# Local environment overrides — never commit real secrets.
# Copy the per-module .env.example to .env and keep it local.
.env
*.env
!*.env.example

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# Terraform
**/.terraform/
*.tfstate
*.tfstate.*
crash.log
*.tfvars
!*.tfvars.example
!*.example.tfvars

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Generated training output
reports/
tmp/
work/
