# Terraform working directories
**/.terraform/*

# Terraform state
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Saved plans
*.tfplan
*.plan

# Variable files may contain secrets
*.tfvars
*.tfvars.json
!*.example.tfvars

# CLI configuration and credentials
.terraformrc
terraform.rc
credentials.tfrc.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Local caches and editor files
.DS_Store
.vscode/
.idea/
__pycache__/
*.pyc
